// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  events       Event[]
  racePatrols  RacePatrol[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Event {
  id             String   @id @default(cuid())
  name           String
  pointLimit     Int      @default(2)
  lanes          Int      @default(4)
  setupComplete  Boolean  @default(false)
  isComplete     Boolean  @default(false)
  isGuest        Boolean  @default(false) // If true, can be claimed
  theme          String   @default("system")
  weightUnit     String   @default("g")
  popularVoteRevealAt DateTime?
  popularVoteRevealCountdownSeconds Int @default(10)
  popularVoteWinnerScoutId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  completedAt    DateTime?
  
  scouts         Scout[]
  heats          Heat[]
  logs           EventLog[]
  kioskSessions  KioskSession[]
  guestKioskLinks GuestKioskLink[]
  popularVotes   PopularVote[]
  popularVoteWinner Scout? @relation("PopularVoteWinner", fields: [popularVoteWinnerScoutId], references: [id], onDelete: SetNull)
  
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Scout {
  id          String   @id @default(cuid())
  name        String
  carNumber   String
  groupName   String?
  weight      Float?
  points      Int      @default(0)
  eliminated  Boolean  @default(false)
  eliminatedAt DateTime?
  eliminatedHeatId String?
  dropped     Boolean  @default(false)
  droppedAt   DateTime?
  sourcePatrolRacerId String?
  laneHistory String   @default("[]") // JSON array of lane numbers
  
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  wonHeats    Heat[]   @relation("HeatWinner")
  eliminatedHeat Heat? @relation("HeatElimination", fields: [eliminatedHeatId], references: [id], onDelete: SetNull)
  popularVoteWins Event[] @relation("PopularVoteWinner")
  votesReceived PopularVote[]
  logs        EventLog[]
  sourcePatrolRacer RacePatrolRacer? @relation(fields: [sourcePatrolRacerId], references: [id], onDelete: SetNull)
}

model Heat {
  id              String   @id @default(cuid())
  laneAssignments String   // JSON array of scout IDs
  finishOrder     String   @default("[]") // JSON array of scout IDs in finish order
  createdAt       DateTime @default(now())
  
  eventId         String
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  winnerScoutId   String?
  winnerScout     Scout?   @relation("HeatWinner", fields: [winnerScoutId], references: [id])
  
  loserScoutIds   String   @default("[]") // JSON array of scout IDs
  eliminatedScouts Scout[] @relation("HeatElimination")
}

model EventLog {
  id           String   @id @default(cuid())
  type         String
  createdAt    DateTime @default(now())
  pointsPenalty Int?

  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  scoutId      String?
  scout        Scout?   @relation(fields: [scoutId], references: [id], onDelete: SetNull)
}

model RacePatrol {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  racers    RacePatrolRacer[]
}

model RacePatrolRacer {
  id        String   @id @default(cuid())
  name      String
  groupName String?
  weight    Float?

  patrolId  String
  patrol    RacePatrol @relation(fields: [patrolId], references: [id], onDelete: Cascade)

  scouts    Scout[]
}

model KioskSession {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  accessExpiresAt DateTime?
  createdAt DateTime @default(now())
  
  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  guestKioskLinkId String?
  guestKioskLink   GuestKioskLink? @relation(fields: [guestKioskLinkId], references: [id], onDelete: SetNull)
}

model PairingRequest {
  id          String   @id @default(cuid())
  qrToken     String   @unique
  pairingCode String
  kioskToken  String
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}

model GuestKioskLink {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  sessions  KioskSession[]
}

model PopularVote {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())

  eventId        String
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  favoriteScoutId String
  favorite       Scout    @relation(fields: [favoriteScoutId], references: [id], onDelete: Cascade)
}
